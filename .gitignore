# Ruby
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/

# Used by dotenv library to load environment variables.
# .env
# Ignore dotenv environment files by default
.env
.env.*
!.env.example

# Ignore Byebug command history file.
.byebug_history

## Specific to Minechat
## 忽略各子项目的运行时文件
/backend/log/*
/backend/tmp/*
/backend/storage/*
/backend/public/system/*
/backend/node_modules/
/backend/.bundle/

/frontend/log/*
/frontend/tmp/*
/frontend/storage/*
/frontend/public/system/*
/frontend/node_modules/
/frontend/.bundle/

/gui/.bundle/

## Environment
/backend/.env
/backend/.env.*
/frontend/.env
/frontend/.env.*
/gui/.env
/gui/.env.*

# Ignore master key for decrypting credentials and more.
/backend/config/master.key
/frontend/config/master.key

# Comment out if using credentials.yml.enc in frontend
# /frontend/config/credentials.yml.enc

