# syntax=docker/dockerfile:1
# Development Dockerfile for Minechat Backend
# Designed for use with docker-compose.dev.yml and volume mounts

ARG RUBY_VERSION=3.4.4
FROM docker.io/library/ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Install dependencies for ibm_db gem and development tools
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libjemalloc2 \
      libyaml-dev \
      pkg-config && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV BUNDLE_PATH="/usr/local/bundle"

# Install gems (will be overridden by volume mount in dev)
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy application code (will be overridden by volume mount in dev)
COPY . .
RUN chmod +x bin/* && sed -i "s/\r$//g" bin/*

# Enable jemalloc
ENV LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit 2>/dev/null || true)

EXPOSE 3000
CMD ["bin/dev"]
