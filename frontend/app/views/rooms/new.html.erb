<h1>新建房间</h1>

<% if @errors %>
  <ul style="color: red">
    <% @errors.each do |error| %>
      <li><%= error %></li>
    <% end %>
  </ul>
<% end %>

<%= form_with model: @room, url: rooms_path, local: true do |f| %>
  <p>
    <%= f.label :name, "房间名称" %><br>
    <%= f.text_field :name %>
  </p>
  <p>
    <%= f.label :room_type, "类型" %><br>
    <%= f.text_field :room_type %>
  </p>
  <p>
    <%= f.submit "创建" %>
  </p>
<% end %>

<%= link_to "返回", rooms_path %>
